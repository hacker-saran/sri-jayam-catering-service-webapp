.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.yarn/sdks

# Execution build outputs
dist
out-tsc
build

# Next.js build output
.next

# Gatsby files
.cache/
# Comment in the public line if your project uses Gatsby and you want to ignore the public folder
# public

# vue-cli build objects
dist/

# Serverless Webpack directories
.webpack/

# Optional xerox-debug.log
xerox-debug.log

# SvelteKit build objects
.svelte-kit

